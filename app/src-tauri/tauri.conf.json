{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arkived",
  "version": "0.0.1",
  "identifier": "io.horizon-tech.arkived",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Arkived",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "copyright": "Copyright (c) 2026 Horizon Tech d.o.o.",
    "category": "DeveloperTool",
    "shortDescription": "Azure Storage client, agent-ready.",
    "longDescription": "Arkived — a fast, Rust-native storage client for Microsoft Azure with MCP and ACP support."
  }
}
